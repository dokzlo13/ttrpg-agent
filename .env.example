# Copy to .env and fill in. .env is gitignored; .env.example is checked in.
#
# Keep this file to simple KEY=value dotenv syntax. The project shell loads it
# before tools run, and individual CLIs also read it when invoked directly.
# Leave optional secret keys commented unless you want this project to override
# shell/global credentials.

# -----------------------------------------------------------------------------
# Web research / pi-web-access
# -----------------------------------------------------------------------------
# Optional. Exa may also work through MCP without a key; Gemini Web may work
# through browser login on supported systems. Project .env is sourced by
# .pi/scripts/pi-shell.sh before pi starts, so uncommented values are visible to
# web tools and override shell/global values.
# EXA_API_KEY=
# PERPLEXITY_API_KEY=
# GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# OpenAI-backed features
# -----------------------------------------------------------------------------
# Required for explicit image generation and for book-ingest Marker LLM modes
# other than TTRPG_MARKER_LLM_MODE=no. Metered.
# OPENAI_API_KEY=

# image-gen defaults. Used by .pi/cli/image-gen; CLI flags override these.
TTRPG_IMAGE_MODEL=gpt-image-1
TTRPG_IMAGE_SIZE=1024x1024
TTRPG_IMAGE_QUALITY=auto
TTRPG_IMAGE_OUTPUT_FORMAT=png
# Must remain under vault/notes/images for the image generation tool.
TTRPG_IMAGE_OUTPUT_DIR=vault/notes/images

# -----------------------------------------------------------------------------
# book-ingest / Marker LLM behavior
# -----------------------------------------------------------------------------
# Preferred setting: no | images-only | text-only | all
#   no          = fast local extraction, no API calls; image files still copied.
#   images-only = normal extraction + LLM captions for Picture/Figure blocks only.
#   text-only   = full Marker LLM cleanup, no image captions.
#   all         = full cleanup plus image captions.
TTRPG_MARKER_LLM_MODE=no
# Legacy fallback if TTRPG_MARKER_LLM_MODE is unset; normally leave commented.
# TTRPG_MARKER_USE_LLM=false
# TTRPG_MARKER_DESCRIBE_IMAGES=false
# OpenAI-compatible endpoint/model for Marker LLM calls.
TTRPG_MARKER_OPENAI_MODEL=gpt-4o-mini
TTRPG_MARKER_OPENAI_BASE_URL=https://api.openai.com/v1
# Marker LLM parallel calls. 2 is a balanced default; use 1 if you still hit TPM
# limits, or 3+ if your account limits are high and imports are too slow.
TTRPG_MARKER_LLM_MAX_CONCURRENCY=2

# -----------------------------------------------------------------------------
# book-ingest / Marker local OCR-layout performance
# -----------------------------------------------------------------------------
# Optional. Override via book-ingest CLI flags. Device: auto | cuda | cpu | mps.
TTRPG_MARKER_DEVICE=auto
# Blank batch sizes let Marker choose. CUDA machines often do well with 8/8/128/8;
# lower these if you run out of VRAM.
TTRPG_MARKER_LAYOUT_BATCH_SIZE=
TTRPG_MARKER_DETECTION_BATCH_SIZE=
TTRPG_MARKER_RECOGNITION_BATCH_SIZE=
TTRPG_MARKER_TABLE_REC_BATCH_SIZE=

# -----------------------------------------------------------------------------
# qmd / embedding runtime overrides
# -----------------------------------------------------------------------------
# Usually leave these unset. pi-shell.sh sets project-local QMD_CONFIG_DIR and
# XDG_CACHE_HOME automatically, and defaults QMD_LLAMA_GPU to auto.
# QMD_LLAMA_GPU=false      # force CPU; any other value lets node-llama-cpp auto-pick
# QMD_CPU_FALLBACK=1       # retry selected qmd GPU failures once on CPU; set 0 to disable
# GGML_CUDA_NO_VMM=1       # WSL2/RTX workaround; pi-shell.sh defaults this to 1
