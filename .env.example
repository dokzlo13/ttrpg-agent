# Copy to .env and fill in. .env is gitignored; .env.example is checked in.
#
# Pi reads provider OAuth state from its own config (see `pi auth login openai-codex`),
# so most users won't need any keys here. The two extensions below need keys
# only if you actually use them.

# pi-web-access — project .env is sourced by .pi/scripts/pi-shell.sh before pi starts.
# Exa can also fall back to MCP with no key. Perplexity/Gemini keys are optional.
# Gemini Web can work via browser login without a key on supported systems.
EXA_API_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=
# Legacy/other Google search tooling, if configured elsewhere.
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# image-gen — OpenAI image generation. Metered; use only on explicit request.
# OPENAI_API_KEY is also used by book-ingest --use-llm (opt-in).
OPENAI_API_KEY=
TTRPG_IMAGE_MODEL=gpt-image-1
TTRPG_IMAGE_SIZE=1024x1024
TTRPG_IMAGE_QUALITY=auto
TTRPG_IMAGE_OUTPUT_FORMAT=png
TTRPG_IMAGE_OUTPUT_DIR=vault/notes/images

# book-ingest — Marker LLM mode.
# Preferred setting: no | images-only | text-only | all
#   no          = fast local extraction, no API calls; image files still copied.
#   images-only = normal extraction + LLM captions for Picture/Figure blocks only.
#   text-only   = full Marker LLM cleanup, no image captions.
#   all         = full cleanup plus image captions.
TTRPG_MARKER_LLM_MODE=no
# Legacy fallback if TTRPG_MARKER_LLM_MODE is unset:
# TTRPG_MARKER_USE_LLM=false
# TTRPG_MARKER_DESCRIBE_IMAGES=false
TTRPG_MARKER_OPENAI_MODEL=gpt-4o-mini
TTRPG_MARKER_OPENAI_BASE_URL=https://api.openai.com/v1

# book-ingest — Marker GPU/perf defaults. Optional. Override via CLI flags.
TTRPG_MARKER_DEVICE=auto
TTRPG_MARKER_LAYOUT_BATCH_SIZE=
TTRPG_MARKER_DETECTION_BATCH_SIZE=
TTRPG_MARKER_RECOGNITION_BATCH_SIZE=
TTRPG_MARKER_TABLE_REC_BATCH_SIZE=
