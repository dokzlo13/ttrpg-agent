# --- local data -------------------------------------------------------------

# Working campaign vault and all user/imported/generated content. These are
# local runtime/data areas and may be real directories, symlinks, or absent
# until bootstrap/tooling recreates the expected structure.
vault
vault/
imports
imports/

# qmd config/index state — rebuildable from vault/imports.
.qmd/
# Project-local persistent caches (Marker/qmd/HuggingFace/torch/uv models,
# book-ingest raw artifacts, lint/test caches, etc). Do not wipe during normal
# qmd/index cleanup.
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Trash directory (for manually deleted/moved files).
.trash/

# --- local pi/runtime caches ------------------------------------------------

.pi/npm/
.pi/git/
.pi-home/

# --- per-tool environments/build output ------------------------------------

**/.venv/
.venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
node_modules/
*.log

# --- editor / OS noise ------------------------------------------------------

.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# --- env & secrets ----------------------------------------------------------

.env
.env.*
!.env.example
